# WhatsApp Cloud API Credentials
# Get these from Meta Developer Portal: https://developers.facebook.com/

# Permanent or temporary access token from Meta
ACCESS_TOKEN=

# Phone Number ID from WhatsApp Business API
PHONE_NUMBER_ID=

# Approved WhatsApp message template name
TEMPLATE_NAME=

# Template language code (e.g., en, en_US, hi)
TEMPLATE_LANGUAGE=en

# Graph API version
API_VERSION=v25.0

# Default country code for phone number normalization (ISO 3166-1 alpha-2)
# Examples: IN (India), US (United States), GB (United Kingdom)
DEFAULT_REGION=IN

# Rate limiting: maximum messages per second (float)
# WhatsApp Business API tier limits apply
RATE_LIMIT_MPS=1.0
